# Copy this file to .env and fill in what you use.
# Values here are read by scripts/scheduled/run.sh and by Claude Code sessions
# via config loader. Missing values just disable the corresponding feature.

# --- Pushover (optional) ---
# Sign up at pushover.net — create an application to get the API token.
# Leave both blank to disable push notifications.
PUSHOVER_TOKEN=
PUSHOVER_USER=

# --- Claude Code defaults ---
# Model for scheduled tasks: sonnet | opus | haiku
CLAUDE_MODEL=sonnet
# Seconds before watchdog kills a task
TIMEOUT_SECS=600

# --- Timezone (for date handling in prompts) ---
# e.g. America/New_York, America/Toronto, America/Edmonton, Europe/London
TZ=America/Edmonton

# --- Ticketing (optional, opt-in during onboarding) ---
# One of: jira | linear | github | none
TICKETING_SYSTEM=none
